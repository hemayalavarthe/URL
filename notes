--{{ url_for("home")}} --> function name home
{{ url_for("static",path="")}} -- if static files are renamed or removed then it is rerouted
url_for usecase 
1. route links like navigation
2. for static files like css, js and images
3. benefit : on updating the mount path, all the link will update automatically
--Path parameters are variables that are part of URL path
--HTTPException -- caughts theexception 
--status -- returns the constants for HTTP status codes 
raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail="post not found")--raises a HTTP exception with 404 not found 
--Validation errors are different exceptions(like unable to parse if string is given instead of number)
--Starlette : Fastapi is built on top of starlette, so HTTPException in starlette captures the correct HTTP status codes
